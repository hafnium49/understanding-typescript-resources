{
  // LESSON 248: TSCONFIG FOR A NODE.JS + TYPESCRIPT PROJECT.
  // Everything the TypeScript compiler needs to know about this project lives
  // inside "compilerOptions". When the "compile" npm script runs `tsc`, the
  // compiler auto-discovers this file and applies the settings below to every
  // .ts file it finds.
  "compilerOptions": {
    // The JavaScript language level the emitted code will use. Because the
    // output here is consumed by Node.js (not an old browser), we can pick a
    // modern dialect and skip heavy down-leveling. Keep this in sync with the
    // minimum Node.js version you intend to support.
    "target": "es2022",

    // Smooths over the mismatch between CommonJS modules (the traditional
    // Node.js format) and ES modules (the `import`/`export` syntax). Some
    // third-party packages still ship CommonJS; this flag makes default
    // imports against those packages behave as students would expect.
    "esModuleInterop": true,

    // Skip type-checking the .d.ts declaration files that ship with npm
    // packages. It trades a bit of theoretical safety for noticeably faster
    // feedback inside the editor and the compiler.
    "skipLibCheck": true,

    // Tells the compiler to emit and resolve modules using Node.js's modern
    // module resolution rules. Paired with "type": "module" in package.json,
    // this keeps `import`/`export` statements working correctly in both our
    // own code and in libraries we install.
    "module": "NodeNext",

    // Destination folder for the compiled .js files. Our "start" script in
    // package.json assumes this path — if you rename it here, update that too.
    "outDir": "dist",

    // Built-in library type definitions to include. "es2022" covers the
    // language features that match our target. "dom" is added even though we
    // are running on the server — without it, TypeScript does not know about
    // the global `console` object and would flag `console.log` as an error.
    "lib": ["es2022", "dom"],

    // Enables TypeScript's strongest type-checking rules as a single switch.
    // Turning this off would let implicit `any` types and other loose patterns
    // slip through, which defeats most of the reason we adopted TypeScript.
    "strict": true,

    // Explicitly loads the Node.js ambient types installed via `@types/node`.
    // Without this, the compiler in use here refuses to resolve core modules
    // like `http` and reports that the `http` identifier cannot be found.
    "types": ["node"],

    // LESSON 254: SWITCHING TO NATIVE NODE.JS TYPESCRIPT EXECUTION.
    // Node.js 22.6+ can execute .ts files directly — no `tsc` pass needed.
    // The three options below adapt the compiler to that workflow so that
    // the editor and a standalone type-check (`tsc` with noEmit) still give
    // us feedback while Node handles the actual runtime stripping of types.

    // Allows `import ... from './foo.ts'` in source code. Under the compile
    // workflow we used to write `./foo.js` because the emitted output is
    // .js; now there is no output step, so the import path has to point at
    // the file that actually exists on disk — the .ts source.
    "allowImportingTsExtensions": true,

    // Tells the compiler never to produce JavaScript files. This is a hard
    // requirement when `allowImportingTsExtensions` is enabled (TypeScript
    // refuses to emit code that references paths with a .ts extension).
    // Running `tsc` now becomes a pure type-check.
    "noEmit": true,

    // Forces every `import`/`export` statement to spell out whether each
    // binding is a runtime value or a type-only symbol. Anything that exists
    // solely in the type system (interfaces, type aliases, type-only class
    // references) must be imported with the `type` keyword. Without this
    // option, TypeScript would silently erase type-only imports for us;
    // with it enabled, Node's lighter-weight type stripper can handle the
    // job because the intent is already spelled out in the source.
    "verbatimModuleSyntax": true,

    // LESSON 255: GUARDING AGAINST NON-STRIPPABLE TYPESCRIPT SYNTAX.
    // Node.js's native TypeScript support operates in a "strip-only" mode by
    // default: it erases TypeScript-specific syntax (type annotations,
    // interfaces, the `type` keyword on imports) and runs what's left as
    // JavaScript. Most TS features are fine because they really are just
    // extra annotations that disappear when removed.
    //
    // A few features, however, are not erasable — they have no pure-JS
    // equivalent and require an actual code transformation. `enum` is the
    // headline example: it compiles into a runtime object with numeric or
    // string key/value mappings. Parameter-property shorthand in classes
    // (e.g. `constructor(private name: string)`) is another. Running a file
    // that uses these under strip-only mode produces an error like
    // "TypeScript enum is not supported in strip-only mode". The workaround
    // Node offers is the `--experimental-transform-types` flag, which
    // performs a real transformation — at a cost: a measurable runtime
    // penalty versus strip-only.
    //
    // Setting `erasableSyntaxOnly: true` flips this safety check to compile
    // time. The editor and `tsc` now refuse code that uses non-strippable
    // syntax, so problems surface while typing rather than at `node`. It
    // requires TypeScript 5.8 or later (we are using 6.0.3 here). The
    // practical advice: stick to strip-only, and replace features like
    // `enum` with alternatives that are pure types — for example a string
    // literal union such as `type TodoType = 'basic' | 'urgent'`.
    "erasableSyntaxOnly": true
  }
}
