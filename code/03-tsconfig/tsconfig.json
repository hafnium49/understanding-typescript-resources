{
  // TSCONFIG.JSON — the TypeScript project configuration file.
  //
  // Created by running: tsc --init
  // This command generates a tsconfig.json with all available options
  // listed (most commented out) along with brief descriptions.
  //
  // Once this file exists in a project folder, the TypeScript compiler
  // (tsc) and your IDE (e.g., VS Code) automatically pick it up. It
  // controls how type checking works, how code is compiled, and which
  // files are included — for this folder and all its subfolders.
  //
  // Most options can be left at their defaults. The ones that matter
  // most are uncommented below and explained in subsequent lessons.
  //
  // For the full reference of every option, see the official docs:
  // https://www.typescriptlang.org/tsconfig (also linked below).
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig to read more about this file */

    /* Projects — advanced settings for multi-project setups (monorepos).
     *
     * These options control how TypeScript handles project references, where
     * a repository contains multiple TypeScript sub-projects that depend on
     * each other. For example, "disableReferencedProjectLoad" prevents
     * TypeScript from loading ALL sub-project files into memory at once,
     * which can dramatically speed up type checking in large monorepos.
     *
     * For single-project setups (like this one), these settings can be
     * safely ignored. */
    // "incremental": true,                              /* Save .tsbuildinfo files to allow for incremental compilation of projects. */
    // "composite": true,                                /* Enable constraints that allow a TypeScript project to be used with project references. */
    // "tsBuildInfoFile": "./.tsbuildinfo",              /* Specify the path to .tsbuildinfo incremental compilation file. */
    // "disableSourceOfProjectReferenceRedirect": true,  /* Disable preferring source files instead of declaration files when referencing composite projects. */
    // "disableSolutionSearching": true,                 /* Opt a project out of multi-project reference checking when editing. */
    // "disableReferencedProjectLoad": true,             /* Reduce the number of projects loaded automatically by TypeScript. */

    /* Language and Environment */

    // TARGET — controls which JavaScript version the compiled output uses.
    //
    // TypeScript can compile your code to older or newer JavaScript syntax.
    // An older target (e.g., ES2016) produces code compatible with older
    // browsers/runtimes — for example, "let" may be downleveled to "var".
    // A newer target (e.g., ES2022) keeps modern syntax like "let", "const",
    // optional chaining, and class fields intact.
    //
    // Choose based on your runtime environment:
    //   - Frontend targeting old browsers → lower target (ES2016, ES2017)
    //   - Frontend targeting modern browsers → ES2020+
    //   - Node.js backend → match your Node version's ES support (ES2022+)
    "target": "ES2022",                                  /* Set the JavaScript language version for emitted JavaScript and include compatible library declarations. */

    // LIB — which built-in type libraries TypeScript should include.
    //
    // TypeScript ships with several pre-built type definition libraries
    // (e.g., "DOM" for HTML element types like HTMLInputElement, "ES2022"
    // for modern JS APIs). When this setting is commented out, TypeScript
    // includes a default set of libraries based on the "target" value.
    //
    // You would only uncomment and configure this explicitly if you need
    // to add or remove specific libraries — for example, excluding "DOM"
    // in a pure Node.js project where browser types are irrelevant, or
    // adding "WebWorker" for service worker code. The value is an array,
    // so you can enable multiple libraries.
    // "lib": [],                                        /* Specify a set of bundled library declaration files that describe the target runtime environment. */

    // JSX — controls how JSX syntax (used in React) is compiled.
    // In most React + TypeScript projects, this is configured for you
    // automatically by build tools like Vite. Decorators (below) are
    // covered in a later course section.
    // "jsx": "preserve",                                /* Specify what JSX code is generated. */
    // "experimentalDecorators": true,                   /* Enable experimental support for legacy experimental decorators. */
    // "emitDecoratorMetadata": true,                    /* Emit design-type metadata for decorated declarations in source files. */
    // "jsxFactory": "",                                 /* Specify the JSX factory function used when targeting React JSX emit, e.g. 'React.createElement' or 'h'. */
    // "jsxFragmentFactory": "",                         /* Specify the JSX Fragment reference used for fragments when targeting React JSX emit e.g. 'React.Fragment' or 'Fragment'. */
    // "jsxImportSource": "",                            /* Specify module specifier used to import the JSX factory functions when using 'jsx: react-jsx*'. */
    // "reactNamespace": "",                             /* Specify the object invoked for 'createElement'. This only applies when targeting 'react' JSX emit. */
    // "noLib": true,                                    /* Disable including any library files, including the default lib.d.ts. */
    // "useDefineForClassFields": true,                  /* Emit ECMAScript-standard-compliant class fields. */
    // "moduleDetection": "auto",                        /* Control what method is used to detect module-format JS files. */

    /* Modules */

    // MODULE — controls how import/export statements are compiled.
    //
    // "NodeNext" supports modern ES module syntax (import/export) for
    // Node.js projects. For projects using a bundler (Webpack, Vite),
    // "preserve" is often a better choice since the bundler handles
    // module resolution itself. This is typically configured for you
    // by project setup tools.
    "module": "NodeNext",                                /* Specify what module code is generated. */

    // ROOTDIR — tells the compiler where your source files live.
    //
    // When set, TypeScript looks for .ts files starting from this folder.
    // The folder structure under rootDir is mirrored in the outDir. For
    // example, with rootDir "./src" and outDir "./dist", the file
    // src/app.ts compiles to dist/app.js, preserving the relative path.
    "rootDir": "./src",                                  /* Specify the root folder within your source files. */
    // "moduleResolution": "node10",                     /* Specify how TypeScript looks up a file from a given module specifier. */
    // "baseUrl": "./",                                  /* Specify the base directory to resolve non-relative module names. */
    // "paths": {},                                      /* Specify a set of entries that re-map imports to additional lookup locations. */
    // "rootDirs": [],                                   /* Allow multiple folders to be treated as one when resolving modules. */
    // "typeRoots": [],                                  /* Specify multiple folders that act like './node_modules/@types'. */
    // "types": [],                                      /* Specify type package names to be included without being referenced in a source file. */
    // "allowUmdGlobalAccess": true,                     /* Allow accessing UMD globals from modules. */
    // "moduleSuffixes": [],                             /* List of file name suffixes to search when resolving a module. */
    // "allowImportingTsExtensions": true,               /* Allow imports to include TypeScript file extensions. Requires '--moduleResolution bundler' and either '--noEmit' or '--emitDeclarationOnly' to be set. */
    // "resolvePackageJsonExports": true,                /* Use the package.json 'exports' field when resolving package imports. */
    // "resolvePackageJsonImports": true,                /* Use the package.json 'imports' field when resolving imports. */
    // "customConditions": [],                           /* Conditions to set in addition to the resolver-specific defaults when resolving imports. */
    // "resolveJsonModule": true,                        /* Enable importing .json files. */
    // "allowArbitraryExtensions": true,                 /* Enable importing files with any extension, provided a declaration file is present. */
    // "noResolve": true,                                /* Disallow 'import's, 'require's or '<reference>'s from expanding the number of files TypeScript should add to a project. */

    /* JavaScript Support — mixing .ts and .js files in the same project.
     *
     * ALLOWJS lets you include plain .js files alongside .ts files.
     * The compiler will not complain about importing from .js files.
     *
     * CHECKJS goes further: it enables TypeScript's type checking even
     * inside .js files. You won't have type annotations there, but
     * TypeScript can still infer types and catch some errors — giving
     * you partial TypeScript benefits without converting files to .ts. */
    "allowJs": true,                                  /* Allow JavaScript files to be a part of your program. Use the 'checkJS' option to get errors from these files. */
    // "checkJs": true,                                  /* Enable error reporting in type-checked JavaScript files. */
    // "maxNodeModuleJsDepth": 1,                        /* Specify the maximum folder depth used for checking JavaScript files from 'node_modules'. Only applicable with 'allowJs'. */

    /* Emit — controls what files the compiler produces. */

    // "declaration": true,                              /* Generate .d.ts files from TypeScript and JavaScript files in your project. */
    // "declarationMap": true,                           /* Create sourcemaps for d.ts files. */
    // "emitDeclarationOnly": true,                      /* Only output d.ts files and not JavaScript files. */

    // SOURCEMAP — generates .map files alongside the compiled JavaScript.
    // Source maps let browser dev tools and debuggers show your original
    // TypeScript code instead of the compiled JavaScript, which makes
    // debugging significantly easier.
    "sourceMap": true,                                /* Create source map files for emitted JavaScript files. */
    // "inlineSourceMap": true,                          /* Include sourcemap files inside the emitted JavaScript. */

    // OUTFILE — bundles all compiled output into a single JavaScript file.
    // In theory, this lets TypeScript act as a basic bundler. In practice,
    // dedicated bundlers (Webpack, Vite) are preferred because they offer
    // more features and better performance. Rarely used.
    // "outFile": "./",                                  /* Specify a file that bundles all outputs into one JavaScript file. If 'declaration' is true, also designates a file that bundles all .d.ts output. */

    // OUTDIR — the folder where compiled .js files are written.
    // Without this, output files land next to their source .ts files.
    // Setting it to "./dist" keeps source and output cleanly separated.
    "outDir": "./dist",                                   /* Specify an output folder for all emitted files. */

    // REMOVECOMMENTS — strips all comments from the compiled output.
    // "removeComments": true,                           /* Disable emitting comments. */

    // NOEMIT — runs type checking without producing any output files.
    // Useful when another tool (e.g., Vite, Babel) handles compilation
    // and you only want TypeScript for error checking.
    // "noEmit": true,                                   /* Disable emitting files from a compilation. */
    // "importHelpers": true,                            /* Allow importing helper functions from tslib once per project, instead of including them per-file. */
    // "downlevelIteration": true,                       /* Emit more compliant, but verbose and less performant JavaScript for iteration. */
    // "sourceRoot": "",                                 /* Specify the root path for debuggers to find the reference source code. */
    // "mapRoot": "",                                    /* Specify the location where debugger should locate map files instead of generated locations. */
    // "inlineSources": true,                            /* Include source code in the sourcemaps inside the emitted JavaScript. */
    // "emitBOM": true,                                  /* Emit a UTF-8 Byte Order Mark (BOM) in the beginning of output files. */
    // "newLine": "crlf",                                /* Set the newline character for emitting files. */
    // "stripInternal": true,                            /* Disable emitting declarations that have '@internal' in their JSDoc comments. */
    // "noEmitHelpers": true,                            /* Disable generating custom helper functions like '__extends' in compiled output. */

    // NOEMITONERROR — prevents output when there are type errors.
    //
    // By default, TypeScript generates .js output files EVEN when there
    // are type errors in your code. This can be surprising — your code
    // has errors, yet new files are still produced. Setting this to true
    // ensures that output is only created when compilation succeeds
    // without any type checking errors.
    "noEmitOnError": true,                            /* Disable emitting files if any type checking errors are reported. */
    // "preserveConstEnums": true,                       /* Disable erasing 'const enum' declarations in generated code. */
    // "declarationDir": "./",                           /* Specify the output directory for generated declaration files. */

    /* Interop Constraints — settings for ES module / CommonJS compatibility.
     *
     * These handle differences between JavaScript's module systems. They
     * are advanced and typically configured for you by project setup tools
     * (Vite, Next.js, etc.). The most commonly used is esModuleInterop. */
    // "isolatedModules": true,                          /* Ensure that each file can be safely transpiled without relying on other imports. */
    // "verbatimModuleSyntax": true,                     /* Do not transform or elide any imports or exports not marked as type-only, ensuring they are written in the output file's format based on the 'module' setting. */
    // "isolatedDeclarations": true,                     /* Require sufficient annotation on exports so other tools can trivially generate declaration files. */
    // "allowSyntheticDefaultImports": true,             /* Allow 'import x from y' when a module doesn't have a default export. */
    "esModuleInterop": true,                             /* Emit additional JavaScript to ease support for importing CommonJS modules. This enables 'allowSyntheticDefaultImports' for type compatibility. */
    // "preserveSymlinks": true,                         /* Disable resolving symlinks to their realpath. This correlates to the same flag in node. */
    "forceConsistentCasingInFileNames": true,            /* Ensure that casing is correct in imports. */

    /* Type Checking — the most important section for most developers.
     *
     * While the other sections above are often configured by project
     * setup tools, this section is where YOU decide how strict TypeScript
     * should be when analyzing your code. Stricter settings catch more
     * potential bugs, but also produce more errors to address. */

    // STRICT — the master switch for strict type checking.
    //
    // Setting this to true enables most of the individual strict options
    // listed below (noImplicitAny, strictNullChecks, etc.) all at once.
    // You do not need to uncomment the individual settings if "strict"
    // is already true — they are included automatically.
    //
    // RECOMMENDED: Keep this set to true for most projects. A strict
    // type checker forces you to write more explicit, less error-prone
    // code and gives you the maximum benefit from using TypeScript.
    // It can feel annoying at times (more errors to fix), but it
    // ultimately prevents subtle bugs from reaching production.
    "strict": true,                                      /* Enable all strict type-checking options. */

    // NOIMPLICITANY — requires explicit types where TypeScript cannot infer.
    //
    // Without this (or with strict: false), a function like:
    //   function add(a, b) { return a + b; }
    // would silently give parameters "a" and "b" the "any" type (a
    // warning appears in the IDE, but no compile error). With this
    // enabled, TypeScript produces an actual error, forcing you to
    // either add explicit type annotations or set "any" intentionally.
    // This prevents accidentally bypassing type checking by forgetting
    // to annotate your parameters. (Included in strict: true.)
    // "noImplicitAny": true,                            /* Enable error reporting for expressions and declarations with an implied 'any' type. */

    // STRICTNULLCHECKS — prevents using potentially null/undefined values.
    //
    // When enabled, TypeScript treats null and undefined as distinct types
    // that must be handled explicitly. This is the setting that causes
    // errors like "Object is possibly 'null'" when using getElementById()
    // without a null check — as seen earlier in the form.ts example.
    // (Included in strict: true.)
    // "strictNullChecks": true,                         /* When type checking, take into account 'null' and 'undefined'. */
    // "strictFunctionTypes": true,                      /* When assigning functions, check to ensure parameters and the return values are subtype-compatible. */
    // "strictBindCallApply": true,                      /* Check that the arguments for 'bind', 'call', and 'apply' methods match the original function. */
    // "strictPropertyInitialization": true,             /* Check for class properties that are declared but not set in the constructor. */
    // "noImplicitThis": true,                           /* Enable error reporting when 'this' is given the type 'any'. */
    // "useUnknownInCatchVariables": true,               /* Default catch clause variables as 'unknown' instead of 'any'. */
    // "alwaysStrict": true,                             /* Ensure 'use strict' is always emitted. */
    // CODE QUALITY CHECKS — not about types, but about cleaner code.
    //
    // These options are NOT included in "strict: true". They must be
    // enabled individually if you want them. They help catch common
    // code quality issues that are unrelated to type correctness:
    //
    //   noUnusedLocals           — flags variables that are declared
    //                              but never read anywhere in the code.
    //   noUnusedParameters       — flags function parameters that are
    //                              accepted but never used in the body.
    //   noFallthroughCasesInSwitch — flags switch cases that fall through
    //                              to the next case without a break or
    //                              return statement, which is usually
    //                              an accidental omission.
    //
    // These are optional but recommended for keeping code tidy.
    // "noUnusedLocals": true,                           /* Enable error reporting when local variables aren't read. */
    // "noUnusedParameters": true,                       /* Raise an error when a function parameter isn't read. */
    // "exactOptionalPropertyTypes": true,               /* Interpret optional property types as written, rather than adding 'undefined'. */
    // "noImplicitReturns": true,                        /* Enable error reporting for codepaths that do not explicitly return in a function. */
    // "noFallthroughCasesInSwitch": true,               /* Enable error reporting for fallthrough cases in switch statements. */
    // NOUNCHECKEDINDEXEDACCESS — adds undefined when accessing by index.
    // When accessing an array element by index (e.g., arr[5]) or an
    // object with an index signature, the result could be undefined if
    // the index is out of bounds. This option forces TypeScript to
    // include undefined in the resulting type, making you handle the
    // possibility of a missing value. Recommended for safer code.
    // "noUncheckedIndexedAccess": true,                 /* Add 'undefined' to a type when accessed using an index. */

    // NOIMPLICITOVERRIDE — useful when working with classes & inheritance.
    // Requires you to mark methods that override a parent class method
    // with the "override" keyword, making inheritance intent explicit.
    // "noImplicitOverride": true,                       /* Ensure overriding members in derived classes are marked with an override modifier. */
    // "noPropertyAccessFromIndexSignature": true,       /* Enforces using indexed accessors for keys declared using an indexed type. */
    // "allowUnusedLabels": true,                        /* Disable error reporting for unused labels. */
    // "allowUnreachableCode": true,                     /* Disable error reporting for unreachable code. */

    /* Completeness */
    // "skipDefaultLibCheck": true,                      /* Skip type checking .d.ts files that are included with TypeScript. */
    "skipLibCheck": true                                 /* Skip type checking all .d.ts files. */
  }
}
